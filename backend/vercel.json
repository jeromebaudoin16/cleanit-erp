{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "10mb" }
    }
  ],
  "routes": [{"src": "/(.*)", "dest": "api/index.js"}],
  "crons": [
    { "path": "/admin/backup", "schedule": "0 2 * * *" },
    { "path": "/admin/daily-recap", "schedule": "0 5 * * *" }
  ]
}
